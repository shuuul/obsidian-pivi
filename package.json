{
  "name": "pivi",
  "version": "0.17.0-beta.0",
  "description": "Pivi - Pi agent embedded in Obsidian sidebar",
  "main": "main.js",
  "scripts": {
    "postinstall": "node scripts/postinstall.mjs",
    "build:css": "node scripts/build-css.mjs",
    "dev": "npm run build:css && node esbuild.config.mjs",
    "build": "node scripts/build.mjs production",
    "check:architecture": "node scripts/check-architecture-boundaries.mjs",
    "check:package-readmes": "node scripts/check-package-readmes.mjs",
    "check:specs": "node scripts/check-specs.mjs",
    "check:pi-pins": "node scripts/check-pi-pins.mjs",
    "check:boundaries": "npm run check:architecture && npm run check:package-readmes && npm run check:i18n-dead-keys && npm run check:specs && npm run check:pi-pins",
    "check:bundle-size": "node scripts/check-bundle-size.mjs",
    "check:i18n-dead-keys": "node scripts/check-i18n-dead-keys.mjs",
    "typecheck": "npm run typecheck:source && npm run typecheck:tests",
    "typecheck:source": "node node_modules/typescript-native/bin/tsc --noEmit -p tsconfig.json",
    "typecheck:tests": "node node_modules/typescript-native/bin/tsc --noEmit -p tests/tsconfig.json",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "node scripts/run-jest.js",
    "test:watch": "node scripts/run-jest.js --watch",
    "test:coverage": "node scripts/run-jest.js --coverage",
    "test:pi-compat": "node scripts/run-jest.js --runInBand tests/integration/piUpgradeCompatibility.test.ts tests/integration/piSessionAppendCompatibility.test.ts tests/unit/pi/session/piSessionManagerPrivateAdapter.test.ts",
    "test:platform-security": "node scripts/run-jest.js --runInBand tests/unit/host/vaultMutationPath.test.ts tests/unit/host/systemProcessRunner.test.ts tests/unit/utils/path.test.ts tests/unit/obsidian-tools/bashAllowlist.test.ts tests/unit/pi/tools/externalFileApi.test.ts tests/unit/pi/mcpProcessEnv.test.ts tests/unit/pi/mcp/mcpStdioDraft.test.ts tests/unit/pi/mcp/mcpValidation.test.ts tests/unit/pi/piMcpBridge.test.ts tests/unit/pi/skills/vaultSkillsService.test.ts tests/unit/pi/skills/skillsStagePublish.test.ts tests/unit/pi/skills/installDefaultVaultSkills.test.ts tests/unit/pi/skills/vaultEnv.test.ts",
    "smoke:obsidian": "node scripts/smoke-obsidian.mjs",
    "analyze:bundle": "node scripts/analyze-bundle.mjs",
    "audit:sessions": "node scripts/audit-sessions.mjs",
    "prepare": "husky",
    "version": "node scripts/sync-version.js && git add manifest.json versions.json README.md",
    "version:beta": "node scripts/prepare-beta-release.js"
  },
  "keywords": [
    "pi-agent",
    "obsidian",
    "obsidian-plugin",
    "productivity",
    "ide"
  ],
  "author": "shuuul",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-plugin-jest": "^29.15.5",
    "eslint-plugin-no-only-tests": "^3.4.0",
    "eslint-plugin-obsidianmd": "^0.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^14.0.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.4.1",
    "obsidian": "^1.13.1",
    "semver": "^7.8.5",
    "ts-jest": "^29.4.12",
    "tsx": "^4.23.1",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "typescript-native": "npm:typescript@^7.0.2"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@earendil-works/pi-agent-core": "0.82.0",
    "@earendil-works/pi-ai": "0.82.0",
    "@earendil-works/pi-coding-agent": "0.82.0",
    "@lobehub/icons-static-svg": "^1.94.0",
    "@modelcontextprotocol/sdk": "~1.29.0",
    "@tanstack/react-virtual": "^3.14.8",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "skills": "1.5.20",
    "tslib": "^2.8.1"
  },
  "overrides": {
    "@earendil-works/pi-coding-agent": {
      "@earendil-works/pi-agent-core": "$@earendil-works/pi-agent-core",
      "@earendil-works/pi-ai": "$@earendil-works/pi-ai"
    },
    "fast-uri": "3.1.4",
    "@hono/node-server": "2.0.11"
  },
  "workspaces": [
    "packages/*"
  ]
}
