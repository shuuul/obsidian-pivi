{
  "name": "pivi",
  "version": "0.9.0",
  "description": "Pivi - Pi agent embedded in Obsidian sidebar",
  "main": "main.js",
  "scripts": {
    "postinstall": "node scripts/postinstall.mjs",
    "build:css": "node scripts/build-css.mjs",
    "dev": "npm run build:css && node esbuild.config.mjs",
    "build": "node scripts/build.mjs production",
    "check:architecture": "node scripts/check-architecture-boundaries.mjs",
    "check:package-readmes": "node scripts/check-package-readmes.mjs",
    "check:boundaries": "npm run check:architecture && npm run check:package-readmes && npm run check:i18n-dead-keys",
    "check:bundle-size": "node scripts/check-bundle-size.mjs",
    "check:i18n-dead-keys": "node scripts/check-i18n-dead-keys.mjs",
    "typecheck": "npm run typecheck:source && npm run typecheck:tests",
    "typecheck:source": "node node_modules/typescript-native/bin/tsc --noEmit -p tsconfig.json",
    "typecheck:tests": "node node_modules/typescript-native/bin/tsc --noEmit -p tests/tsconfig.json",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "node scripts/run-jest.js",
    "test:watch": "node scripts/run-jest.js --watch",
    "test:coverage": "node scripts/run-jest.js --coverage",
    "analyze:bundle": "node scripts/analyze-bundle.mjs",
    "prepare": "husky",
    "version": "node scripts/sync-version.js && git add manifest.json versions.json README.md"
  },
  "keywords": [
    "pi-agent",
    "obsidian",
    "obsidian-plugin",
    "productivity",
    "ide"
  ],
  "author": "shuuul",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-plugin-jest": "^29.15.4",
    "eslint-plugin-no-only-tests": "^3.4.0",
    "eslint-plugin-obsidianmd": "^0.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.4.1",
    "obsidian": "^1.13.1",
    "ts-jest": "^29.4.9",
    "tsx": "^4.23.1",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "typescript-native": "npm:typescript@^7.0.2"
  },
  "dependencies": {
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@cfworker/json-schema": "^4.1.1",
    "@earendil-works/pi-agent-core": "^0.80.6",
    "@earendil-works/pi-ai": "^0.80.6",
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@lobehub/icons-static-svg": "^1.91.0",
    "@modelcontextprotocol/sdk": "~1.29.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tslib": "^2.8.1"
  },
  "overrides": {
    "@earendil-works/pi-coding-agent": {
      "@earendil-works/pi-agent-core": "$@earendil-works/pi-agent-core",
      "@earendil-works/pi-ai": "$@earendil-works/pi-ai"
    }
  },
  "workspaces": [
    "packages/*"
  ]
}
